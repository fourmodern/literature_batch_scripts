# OpenAI API Configuration (for GPT models)
OPENAI_API_KEY=<paste-your-key-here>

# Google Gemini API Configuration (for multimodal support)
GEMINI_API_KEY=<paste-your-key-here>

# Zotero API Configuration
ZOTERO_USER_ID=your_user_id
ZOTERO_API_KEY=<paste-your-key-here>

# Directory Paths
# PDF_DIR is optional - will auto-detect Zotero directory if not set
# Common locations:
#   macOS: ~/Zotero or ~/Documents/Zotero
#   Windows: ~/Zotero or ~/Documents/Zotero  
#   Linux: ~/Zotero or ~/.zotero/zotero
# PDF_DIR=/Users/username/Zotero
OUTPUT_DIR=./ObsidianVault/LiteratureNotes/

# Optional: mirror destination for a second Obsidian vault (e.g. iOS vault on
# iCloud). When set, zotero_auto_sync runs sync_to_llm_wiki.py after each
# successful batch so the second vault stays in sync. Leave unset to disable.
# LLM_WIKI_SOURCES="/Users/<you>/Library/Mobile Documents/iCloud~md~obsidian/Documents/llm-wiki/llm-wiki/sources"

# Model Selection
# For text-only processing (default: gpt-5.2-pro):
# MODEL=gpt-5.5      # 2026-04 latest, $5/$30 per M tok, 1M context
# MODEL=gpt-5.5-pro  # Highest quality, $30/$180 per M tok
# MODEL=gpt-5.4      # 2026-03, $2.50/$15 per M tok (sweet spot)
# MODEL=gpt-5.2-pro  # 2025-12, $1.75/$14 per M tok (current default)
# MODEL=gpt-4o-mini  # Cheapest, $0.15/$0.60 per M tok (used internally for keywords/sections)
# MODEL=gpt-4o       # Older flagship

# For multimodal processing (images + text):
# GEMINI_MODEL=gemini-1.5-pro      # Default: best for multimodal
# GEMINI_MODEL=gemini-1.5-flash    # Faster, less expensive

# Processing mode
# SUMMARIZER=gpt      # Use GPT models (text only)
# SUMMARIZER=gemini   # Use Gemini models (supports images)

# Pinecone Configuration (for RAG system)
PINECONE_API_KEY=<paste-your-key-here>
PINECONE_ENVIRONMENT=gcp-starter  # or your environment
PINECONE_INDEX_NAME=literature-rag

# AI Tool Links Configuration
# Comma-separated list of AI tools to include in markdown notes
# Available: scispace,notebooklm,chatpdf,perplexity,elicit,consensus,scholar_gpt,claude
AI_TOOLS=scispace,notebooklm,chatpdf,perplexity